{
  "name": "@agi-security/openclaw-security-harness",
  "version": "0.1.0",
  "description": "AGI.security OpenClaw Harness — security evaluation harness for OpenClaw-based apps and agent workflows",
  "type": "module",
  "bin": {
    "openclaw-sec": "./src/cli/index.js"
  },
  "scripts": {
